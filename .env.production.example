# Database (local PostgreSQL container)
DATABASE_URL=postgresql://appuser:changeme@db:5432/fitmanager
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fitmanager

# Auth
BETTER_AUTH_URL=https://yourdomain.com
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI
OPENAI_API_KEY=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=training-manager

# Public (set as build args in docker-compose.yml)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_S3_BUCKET_URL=https://training-manager.s3.eu-central-1.amazonaws.com

# Sentry (for source map uploads during build)
SENTRY_AUTH_TOKEN=
